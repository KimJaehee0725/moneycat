# Core app
AUTH_SECRET=replace-with-at-least-32-characters
AUTH_COOKIE_NAME=moneycat_session
APP_TIMEZONE=Asia/Seoul
APP_CURRENCY=KRW

# Local database URL for non-docker local development
DATABASE_URL=postgresql://moneycat:moneycat_local_password@localhost:5432/moneycat?schema=public

# Docker Compose / NAS deployment
POSTGRES_DB=moneycat
POSTGRES_USER=moneycat
POSTGRES_PASSWORD=moneycat_local_password
DOMAIN=:80
